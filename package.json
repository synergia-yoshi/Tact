{
  "name": "tact-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 127.0.0.1 --port 5173",
    "build": "vite build --config vite.config.ts",
    "build:demo": "vite build --config vite.config.ts",
