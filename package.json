  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^26.0.1",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.0"
  }
}
