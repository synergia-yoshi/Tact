# Never commit real secrets. Public repo secret leaks can lead to immediate abuse.
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
PRODUCT_HUNT_TOKEN=

# Default model is Opus 4.8 as requested.
ANTHROPIC_MODEL=claude-opus-4-8

# Cost guardrails. One scheduled run per day means this is effectively the monthly cap / 30.
HERMES_DAILY_API_BUDGET_USD=1.50

# Candidate and delivery controls.
MAX_CANDIDATES_PER_RUN=80
MAX_DELIVERIES_PER_RUN=5
TTP_SCORE_THRESHOLD=18
LLM_BATCH_SIZE=5

# Source toggles.
ENABLE_PRODUCT_HUNT_GRAPHQL=true
ENABLE_GITHUB_TRENDING=false
ENABLE_REDDIT=false

# Dry run avoids Slack posting and state mutation. Dummy mode uses scripts/run-dummy.ts.
DRY_RUN=false
