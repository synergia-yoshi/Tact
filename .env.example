APP_ENV=local
APP_NAME=Tact API
MEDIA_ADAPTER=mock
LLM_ADAPTER=mock
MEASUREMENT_ADAPTER=mock
STORAGE_BACKEND=memory
# Local only. APP_ENV=production refuses to start unless AUTH_MODE=oidc and IAP is configured.
AUTH_MODE=disabled
AUTH_ISSUER=tact-local
AUTH_AUDIENCE=tact-api
AUTH_CLOCK_SKEW_SECONDS=60
AUTH_MAX_TOKEN_SECONDS=3600
AUTH_REPLAY_PROTECTION=false

# Required when AUTH_MODE=oidc.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Required in production. App validates the IAP assertion before bearer auth.
IAP_REQUIRED=false
IAP_ISSUER=
IAP_AUDIENCE=
IAP_JWKS_URL=
MOCK_MEDIA_ACCOUNT_ID=mock-account-001
MOCK_LLM_MODEL=tact-mock-v3

# Set STORAGE_BACKEND=firestore only in a server runtime with GCP credentials.
GCP_PROJECT_ID=
FIRESTORE_DATABASE=
FIRESTORE_COLLECTION_PREFIX=tact_mvp_v3

# Set these only on the server/runtime environment. Do not expose them to clients.
# Secret Manager refs are supported as sm://projects/<project>/secrets/<name>/versions/latest.
MEDIA_API_BASE_URL=
MEDIA_API_KEY=
LLM_API_BASE_URL=
LLM_API_KEY=
# Required when AUTH_MODE=signed_bearer. Local/dev only; production requires OIDC.
AUTH_TOKEN_SECRET=
